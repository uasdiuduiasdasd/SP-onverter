<Page x:Class="SPConverter.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Настройки"
      Background="Transparent"
      FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <Page.Resources>
        <Style x:Key="LanguageSelectorButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="13"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AppButtonSecondaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AppPopupBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  PreviewMouseWheel="OnPageScrollViewerPreviewMouseWheel">
        <Grid Margin="24,16,24,16">
            <StackPanel HorizontalAlignment="Stretch">
                <!-- Заголовок страницы -->
                <TextBlock Text="{DynamicResource Settings_Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="{DynamicResource AppTextBrush}"/>
                
                <!-- Персонализация -->
                <TextBlock Text="{DynamicResource Settings_Personalization}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource AppTextBrush}"/>
                <Grid Margin="0,0,0,16">
                    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.03" Color="Black" />
                        </Border.Effect>
                    </Border>
                    <Border Background="{DynamicResource AppCardBrush}" 
                            BorderBrush="{DynamicResource AppCardBorderBrush}" 
                            BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                        <!-- Тема оформления -->
                        <StackPanel Margin="18,12,18,10">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <ui:SymbolIcon Grid.Column="0" Symbol="Color24" FontSize="20" Foreground="{DynamicResource AppTextBrush}" Opacity="0.7" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Settings_ThemeTitle}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AppTextBrush}"/>
                                    <TextBlock Text="{DynamicResource Settings_ThemeDesc}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                            
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="30,0,0,0">
                                <RadioButton Content="{DynamicResource Theme_System}" GroupName="Theme" Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding CurrentTheme, Converter={StaticResource StringMatchConverter}, ConverterParameter=System}"/>
                                <RadioButton Content="{DynamicResource Theme_Light}" GroupName="Theme" Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding CurrentTheme, Converter={StaticResource StringMatchConverter}, ConverterParameter=Light}"/>
                                <RadioButton Content="{DynamicResource Theme_Dark}" GroupName="Theme" Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding CurrentTheme, Converter={StaticResource StringMatchConverter}, ConverterParameter=Dark}"/>
                                <RadioButton Content="{DynamicResource Theme_BW}" GroupName="Theme" Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding CurrentTheme, Converter={StaticResource StringMatchConverter}, ConverterParameter=BW}"/>
                            </WrapPanel>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{DynamicResource AppCardBorderBrush}" Opacity="0.5" Margin="18,0"/>

                        <!-- Прозрачность -->
                        <Grid Margin="18,12,18,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <ui:SymbolIcon Grid.Column="0" Symbol="Grid24" FontSize="20" Foreground="{DynamicResource AppTextBrush}" Opacity="0.7" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Settings_TransparencyTitle}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AppTextBrush}"/>
                                <TextBlock Text="{DynamicResource Settings_TransparencyDesc}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}"/>
                            </StackPanel>
                            
                            <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding UseTransparency, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
                </Grid>

                <!-- Основные -->
                <TextBlock Text="{DynamicResource Settings_General}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource AppTextBrush}"/>
                <Grid Margin="0,0,0,16">
                    <!-- Тень -->
                    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.03" Color="Black" />
                        </Border.Effect>
                    </Border>
                    <!-- Контент -->
                    <Border Background="{DynamicResource AppCardBrush}" 
                            BorderBrush="{DynamicResource AppCardBorderBrush}" 
                            BorderThickness="1" CornerRadius="8">
                    <Grid Margin="18,12,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <ui:SymbolIcon Grid.Column="0" Symbol="Globe24" FontSize="20" Foreground="{DynamicResource AppTextBrush}" Opacity="0.7" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Settings_LanguageTitle}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AppTextBrush}"/>
                            <TextBlock Text="{DynamicResource Settings_LanguageDesc}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                        
                        <Button x:Name="LanguageButton"
                                Grid.Column="2"
                                Width="136"
                                Style="{StaticResource LanguageSelectorButtonStyle}"
                                Click="OnLanguageButtonClick">
                            <Button.Content>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding CurrentLanguageName}" VerticalAlignment="Center"/>
                                    <ui:SymbolIcon Grid.Column="1" Symbol="ChevronDown24" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </Button.Content>
                            <Button.ContextMenu>
                                <ContextMenu Background="{DynamicResource AppPopupBrush}" BorderBrush="{DynamicResource AppPopupBorderBrush}" Placement="Bottom">
                                    <MenuItem Header="Русский" Tag="0" Click="OnLanguageMenuItemClick"/>
                                    <MenuItem Header="English" Tag="1" Click="OnLanguageMenuItemClick"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>
                </Border>
                </Grid>

                <!-- Конвертация -->
                <TextBlock Text="{DynamicResource Settings_Conversion}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource AppTextBrush}"/>
                <Grid Margin="0,0,0,16">
                    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.03" Color="Black" />
                        </Border.Effect>
                    </Border>
                    <Border Background="{DynamicResource AppCardBrush}"
                            BorderBrush="{DynamicResource AppCardBorderBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <Grid Margin="18,12,18,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:SymbolIcon Grid.Column="0" Symbol="Delete24" FontSize="20" Foreground="{DynamicResource AppTextBrush}" Opacity="0.7" Margin="0,0,10,0" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Convert_DeleteOriginal}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AppTextBrush}"/>
                                    <TextBlock Text="{DynamicResource Convert_DeleteOriginal_Tooltip}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap"/>
                                </StackPanel>

                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding DeleteOriginalsByDefault, Mode=TwoWay}" VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource AppCardBorderBrush}" Opacity="0.5" Margin="18,0"/>

                            <Grid Margin="18,12,18,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:SymbolIcon Grid.Column="0" Symbol="Document24" FontSize="20" Foreground="{DynamicResource AppTextBrush}" Opacity="0.7" Margin="0,0,10,0" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Convert_ExtractAllPages}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AppTextBrush}"/>
                                    <TextBlock Text="{DynamicResource Convert_ExtractAllPages_Tooltip}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap"/>
                                </StackPanel>

                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding ExtractAllPagesByDefault, Mode=TwoWay}" VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource AppCardBorderBrush}" Opacity="0.5" Margin="18,0"/>

                            <Grid Margin="18,12,18,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:SymbolIcon Grid.Column="0" Symbol="Folder24" FontSize="20" Foreground="{DynamicResource AppTextBrush}" Opacity="0.7" Margin="0,0,10,0" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Settings_AlwaysIncludeSubfolders}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AppTextBrush}"/>
                                    <TextBlock Text="{DynamicResource Settings_AlwaysIncludeSubfoldersDesc}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap"/>
                                </StackPanel>

                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding AlwaysIncludeSubfolders, Mode=TwoWay}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- О программе -->
                <TextBlock Text="{DynamicResource Settings_About}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource AppTextBrush}"/>
                <Grid Margin="0,0,0,16">
                    <!-- Тень -->
                    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.03" Color="Black" />
                        </Border.Effect>
                    </Border>
                    <!-- Контент -->
                    <Border Background="{DynamicResource AppCardBrush}" 
                            BorderBrush="{DynamicResource AppCardBorderBrush}" 
                            BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Grid Margin="18,12,18,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" Source="pack://application:,,,/Assets/Logo.ico" Width="48" Height="48" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,14,0" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="SPConverter" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding AppVersion}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Cursor="Hand" MouseDown="OnGitHubLinkClick">
                                    <TextBlock Text="Official GitHub Repository" Foreground="{DynamicResource AppAccentBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    <ui:SymbolIcon Symbol="Open24" FontSize="11" Foreground="{DynamicResource AppAccentBrush}" Margin="4,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="2" Content="{DynamicResource Support_Project}" Style="{StaticResource PrimaryButtonStyle}" Click="OnSupportProjectClick" VerticalAlignment="Center"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource AppCardBorderBrush}" Opacity="0.5" Margin="18,0"/>

                        <Grid Margin="18,12,18,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ui:SymbolIcon Grid.Column="0" Symbol="Window24" FontSize="20" Foreground="{DynamicResource AppTextBrush}" Opacity="0.7" Margin="0,0,10,0" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Settings_ShowSupportInHeader}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AppTextBrush}"/>
                                <TextBlock Text="{DynamicResource Settings_ShowSupportInHeaderDesc}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>

                            <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding ShowSupportButtonInHeader, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
