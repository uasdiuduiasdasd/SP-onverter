<Page x:Class="SPConverter.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Настройки"
      Background="Transparent"
      FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,16,24,16">
            <StackPanel HorizontalAlignment="Stretch">
                <!-- Заголовок страницы -->
                <TextBlock Text="{DynamicResource Settings_Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="{DynamicResource AppTextBrush}"/>
                
                <!-- Персонализация -->
                <TextBlock Text="{DynamicResource Settings_Personalization}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource AppTextBrush}"/>
                <Grid Margin="0,0,0,16">
                    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.03" Color="Black" />
                        </Border.Effect>
                    </Border>
                    <Border Background="{DynamicResource AppCardBrush}" 
                            BorderBrush="{DynamicResource AppCardBorderBrush}" 
                            BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                        <!-- Тема оформления -->
                        <StackPanel Margin="18,12,18,10">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <ui:SymbolIcon Grid.Column="0" Symbol="Color24" FontSize="20" Foreground="{DynamicResource AppTextBrush}" Opacity="0.7" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Settings_ThemeTitle}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AppTextBrush}"/>
                                    <TextBlock Text="{DynamicResource Settings_ThemeDesc}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                            
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="30,0,0,0">
                                <RadioButton Content="{DynamicResource Theme_System}" GroupName="Theme" Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding CurrentTheme, Converter={StaticResource StringMatchConverter}, ConverterParameter=System}"/>
                                <RadioButton Content="{DynamicResource Theme_Light}" GroupName="Theme" Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding CurrentTheme, Converter={StaticResource StringMatchConverter}, ConverterParameter=Light}"/>
                                <RadioButton Content="{DynamicResource Theme_Dark}" GroupName="Theme" Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding CurrentTheme, Converter={StaticResource StringMatchConverter}, ConverterParameter=Dark}"/>
                                <RadioButton Content="{DynamicResource Theme_BW}" GroupName="Theme" Style="{StaticResource ChipToggleStyle}" IsChecked="{Binding CurrentTheme, Converter={StaticResource StringMatchConverter}, ConverterParameter=BW}"/>
                            </WrapPanel>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{DynamicResource AppCardBorderBrush}" Opacity="0.5" Margin="18,0"/>

                        <!-- Прозрачность -->
                        <Grid Margin="18,12,18,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <ui:SymbolIcon Grid.Column="0" Symbol="Grid24" FontSize="20" Foreground="{DynamicResource AppTextBrush}" Opacity="0.7" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Settings_TransparencyTitle}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AppTextBrush}"/>
                                <TextBlock Text="{DynamicResource Settings_TransparencyDesc}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}"/>
                            </StackPanel>
                            
                            <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding UseTransparency, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
                </Grid>

                <!-- Основные -->
                <TextBlock Text="{DynamicResource Settings_General}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource AppTextBrush}"/>
                <Grid Margin="0,0,0,16">
                    <!-- Тень -->
                    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.03" Color="Black" />
                        </Border.Effect>
                    </Border>
                    <!-- Контент -->
                    <Border Background="{DynamicResource AppCardBrush}" 
                            BorderBrush="{DynamicResource AppCardBorderBrush}" 
                            BorderThickness="1" CornerRadius="8">
                    <Grid Margin="18,12,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <ui:SymbolIcon Grid.Column="0" Symbol="Globe24" FontSize="20" Foreground="{DynamicResource AppTextBrush}" Opacity="0.7" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Settings_LanguageTitle}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource AppTextBrush}"/>
                            <TextBlock Text="{DynamicResource Settings_LanguageDesc}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}"/>
                        </StackPanel>
                        
                        <ComboBox Grid.Column="2" Width="110" SelectedIndex="{Binding CurrentLanguageIndex, Mode=TwoWay}" VerticalAlignment="Center" Background="{DynamicResource AppInputBrush}" BorderBrush="{DynamicResource AppInputBorderBrush}" Foreground="{DynamicResource AppTextBrush}" FontSize="13">
                            <ComboBoxItem Content="Русский"/>
                            <ComboBoxItem Content="English"/>
                        </ComboBox>
                    </Grid>
                </Border>
                </Grid>

                <!-- О программе -->
                <TextBlock Text="{DynamicResource Settings_About}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource AppTextBrush}"/>
                <Grid Margin="0,0,0,16">
                    <!-- Тень -->
                    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.03" Color="Black" />
                        </Border.Effect>
                    </Border>
                    <!-- Контент -->
                    <Border Background="{DynamicResource AppCardBrush}" 
                            BorderBrush="{DynamicResource AppCardBorderBrush}" 
                            BorderThickness="1" CornerRadius="8">
                    <Grid Margin="18,12,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Логотип приложения -->
                        <Image Grid.Column="0" Source="pack://application:,,,/Assets/Logo.ico" Width="48" Height="48" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="SPConverter" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding AppVersion}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Cursor="Hand" MouseDown="OnGitHubLinkClick">
                                <TextBlock Text="Official GitHub Repository" Foreground="{DynamicResource AppAccentBrush}" FontSize="11" FontWeight="SemiBold"/>
                                <ui:SymbolIcon Symbol="Open24" FontSize="11" Foreground="{DynamicResource AppAccentBrush}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
