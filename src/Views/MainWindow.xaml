<ui:FluentWindow x:Class="SPConverter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="SP Converter" Height="810" Width="570" MinWidth="460" MinHeight="650"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        Icon="pack://application:,,,/Assets/Logo.ico"
        Foreground="{DynamicResource AppTextBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="Transparent" BorderBrush="{DynamicResource AppNavBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14,6" Margin="3,0">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                  TextElement.FontSize="13" 
                                                  TextElement.FontWeight="Medium"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                                <Rectangle x:Name="underline" Height="2" Fill="{DynamicResource AppAccentBrush}" VerticalAlignment="Bottom" Margin="0,0,0,-6" Visibility="Hidden"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AppToggleInactiveHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AppInputBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
                                <Setter TargetName="underline" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <ui:TitleBar Grid.Row="0" Title="SP Converter">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/Logo.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Разделитель под заголовком -->
        <Rectangle Grid.Row="1" Height="1" Fill="{DynamicResource AppCardBorderBrush}" Opacity="0.3" Margin="0,0,0,0" Panel.ZIndex="10"/>

        <!-- Кастомный Компактный Toolbar -->
        <Grid Grid.Row="2" Margin="24,10,24,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <RadioButton Content="{DynamicResource Nav_MassConvert}" GroupName="Tabs" Style="{StaticResource TabButtonStyle}" IsChecked="True" Checked="NavMass_Checked"/>
                <RadioButton Content="{DynamicResource Nav_SingleConvert}" GroupName="Tabs" Style="{StaticResource TabButtonStyle}" Checked="NavSingle_Checked"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <RadioButton Content="{DynamicResource Nav_Settings}" GroupName="Tabs" Style="{StaticResource TabButtonStyle}" Checked="NavSettings_Checked"/>
            </StackPanel>
        </Grid>

        <!-- Разделительная линия -->
        <Rectangle Grid.Row="3" Height="1" Fill="{DynamicResource AppCardBorderBrush}" Opacity="0.5"/>

        <!-- Контент страниц -->
        <Frame Grid.Row="4" x:Name="ContentFrame" NavigationUIVisibility="Hidden" />
        
        <ui:SnackbarPresenter x:Name="SnackbarPresenter" Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,24"/>

        <!-- Кастомное уведомление в цветах текущей темы с кнопкой Открыть папку -->
        <Border Grid.Row="4" x:Name="NotificationToast" 
                HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                Margin="0,0,0,24" Padding="18,12" 
                Background="{DynamicResource AppCardBrush}" 
                BorderBrush="{DynamicResource AppCardBorderBrush}" 
                BorderThickness="1" CornerRadius="8"
                Visibility="Collapsed" Panel.ZIndex="1000">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.15" Color="Black" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon x:Name="NotificationIcon" Symbol="CheckmarkCircle24" FontSize="24" Foreground="{DynamicResource AppAccentBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center" Margin="0,0,20,0" MaxWidth="360">
                    <TextBlock x:Name="NotificationTitle" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource AppTextBrush}"/>
                    <TextBlock x:Name="NotificationMessage" FontSize="12" Opacity="0.8" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>
                <Button x:Name="NotificationOpenFolderBtn" Content="{DynamicResource Msg_OpenFolder}" Style="{StaticResource PrimaryButtonStyle}" Padding="14,6" FontSize="12" VerticalAlignment="Center" Click="OnNotificationOpenFolderClick"/>
                <Button Content="✕" Style="{StaticResource SecondaryButtonStyle}" BorderThickness="0" Background="Transparent" Padding="6,4" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center" Click="OnNotificationCloseClick"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
